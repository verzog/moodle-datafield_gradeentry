<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/data/field/gradeentry/db" VERSION="20251208"
    COMMENT="XMLDB file for Moodle mod/data/field/gradeentry"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="datafield_gradeentry_grades" COMMENT="Grade metadata for database activity entries">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="dataid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="ID from mdl_data"/>
        <FIELD NAME="recordid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="ID from mdl_data_records"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Student who owns the entry"/>
        <FIELD NAME="graderid" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Teacher who last graded"/>
        <FIELD NAME="feedback" TYPE="text" NOTNULL="false" COMMENT="Teacher feedback text"/>
        <FIELD NAME="feedbackformat" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="released" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="1 = grade visible to student"/>
        <FIELD NAME="submission_status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="notsubmitted" COMMENT="Student submission status: notsubmitted, draft, submitted, resubmit"/>
        <FIELD NAME="requireresubmission" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="1 = teacher requires student to resubmit"/>
        <FIELD NAME="rubric_scores" TYPE="text" NOTNULL="false" COMMENT="JSON array of per-criterion scores for rubric grading"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_dataid" TYPE="foreign" FIELDS="dataid" REFTABLE="data" REFFIELDS="id"/>
        <KEY NAME="fk_recordid" TYPE="foreign" FIELDS="recordid" REFTABLE="data_records" REFFIELDS="id"/>
        <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="dataid_recordid" UNIQUE="true" FIELDS="dataid, recordid"/>
        <INDEX NAME="dataid_userid" UNIQUE="false" FIELDS="dataid, userid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
